{
  "name": "@org.vibevm/vibeterm",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "vibeterm — the complex terminal workspace: a multi-tab Electron + SolidJS shell, AI-UI-ready by construction, built on the vibeterm action/AIUI core (PROP-046/047).",
  "engines": {
    "node": ">=22.6"
  },
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "test": "npm run test:lib && npm run test:engine",
    "test:lib": "node --test test/args.test.mjs test/keymap.test.mjs",
    "test:engine": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:engine": "esbuild src/engine/index.ts --bundle --format=esm --platform=node --outfile=dist/engine/index.js",
    "build:chrome": "vite build",
    "build": "npm run build:engine && npm run build:chrome",
    "package": "node scripts/package.mjs"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/headless": "^5.5.0",
    "@xterm/xterm": "^5.5.0",
    "electron": "^32.0.0",
    "node-pty": "^1.1.0",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@electron/rebuild": "^4.0.0",
    "@kobalte/core": "^0.13.11",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^2.1.0"
  }
}
